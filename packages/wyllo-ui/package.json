{
  "name": "@chebert-pd/ui",
  "version": "2.3.0",
  "description": "Wyllo Design System — components, tokens, and utilities",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./globals.css": "./globals.css",
    "./metadata/*": "./src/components/*.metadata.json",
    "./governance-rules.json": "./governance-rules.json",
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "bin": {
    "audit-governance": "./dist/cli/audit-governance.js"
  },
  "files": [
    "dist",
    "globals.css",
    "governance-rules.json",
    "src/components/*.metadata.json",
    "src/components/*.tsx"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "audit": "node ./dist/cli/audit-governance.js --scope src/components --all --mode ds",
    "test": "node --import tsx --test src/cli/__tests__/*.test.ts"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.0.0",
    "@tanstack/react-table": ">=8.0.0",
    "class-variance-authority": ">=0.7.0",
    "clsx": ">=2.0.0",
    "cmdk": ">=1.0.0",
    "date-fns": ">=4.0.0",
    "input-otp": ">=1.0.0",
    "lucide-react": ">=0.400.0",
    "radix-ui": ">=1.0.0",
    "react": ">=18.0.0",
    "react-day-picker": ">=9.0.0",
    "react-dom": ">=18.0.0",
    "react-hook-form": ">=7.0.0",
    "react-resizable-panels": ">=2.0.0",
    "recharts": ">=2.0.0",
    "sonner": ">=2.0.0",
    "tailwind-merge": ">=3.0.0",
    "vaul": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "recharts": {
      "optional": true
    },
    "@tanstack/react-table": {
      "optional": true
    },
    "react-day-picker": {
      "optional": true
    },
    "date-fns": {
      "optional": true
    },
    "vaul": {
      "optional": true
    },
    "@base-ui/react": {
      "optional": true
    },
    "sonner": {
      "optional": true
    },
    "cmdk": {
      "optional": true
    },
    "input-otp": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "react-resizable-panels": {
      "optional": true
    }
  },
  "devDependencies": {
    "@base-ui/react": "^1.2.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.4",
    "tailwind-merge": "^3.4.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vaul": "^1.1.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chebert-pd/big-wylly-style.git",
    "directory": "packages/wyllo-ui"
  }
}
